rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Only allow read/write if the user is signed in, accessing their own document,
      // and their Google account email is exactly one of the authorized emails.
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId 
                         && (request.auth.token.email == "vneeth@gmail.com" || request.auth.token.email == "manju.jobs@gmail.com");
    }
  }
}
