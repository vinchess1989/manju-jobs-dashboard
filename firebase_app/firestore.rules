rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthorized() {
      return request.auth != null && (
        request.auth.token.email == "vneeth@gmail.com" || 
        request.auth.token.email == "manju.jobs@gmail.com" ||
        request.auth.token.email == "vineethkaimal1989@gmail.com" ||
        request.auth.token.email == "munchnambiar@gmail.com" ||
        request.auth.token.email == "vneethkaimal1989@gmail.com"
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId && isAuthorized();
    }
    
    match /user_feedback/{docId} {
      allow read, write: if isAuthorized();
    }
  }
}
